#2 confirma se o numero é par
numero = int(input("escolha um numero aleatorio: ")) # a variavel 'numero' recebera um numero inteiro
if numero % 2 == 0: # ira verificar se o numero é divisivel por 2 ou igual a 0
    print("ele é par") # se é par mostrara que é par 
else:                  # se não
    print("ele é impar") # mostrara que é impar
